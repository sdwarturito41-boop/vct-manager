generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Auth ─────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  save      Save?
  team      Team?    // backward-compat: routers still use user.team relation
}

// ───────────────── Save = one career per user ─────────────────
model Save {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  // All world-state tables are scoped by saveId; cascade-delete on save removal.
  teams         Team[]
  matches       Match[]
  seasons       Season[]
  coaches       Coach[]
  mapPools      MapPool[]
  metaPatches   MetaPatch[]
  scrims        Scrim[]
  messages      Message[]
  sponsors      Sponsor[]
  injuries      Injury[]
  transferOffers TransferOffer[]
  trainingSessions TrainingSession[]
  playerAgentPools PlayerAgentPool[]
}

model Team {
  id             String   @id @default(cuid())
  saveId         String?
  save           Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  // Backward-compat: legacy routers query the user's team via `userId`. Kept as
  // optional unique FK so existing code keeps working until fully migrated to saveId.
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPlayerTeam   Boolean  @default(false)  // exactly one per save (user's team)
  name           String
  tag            String
  region         Region
  logoUrl        String?
  budget         Int      @default(1000000)
  players        Player[]
  skillAim         Int       @default(0)
  skillUtility     Int       @default(0)
  skillTeamplay    Int       @default(0)
  lastTrainedWeek  Int       @default(0)
  wins            Int       @default(0)
  losses          Int       @default(0)
  champPts        Int       @default(0)
  prestige        Int       @default(50)
  playstyle       Playstyle @default(Balanced)
  coachId         String?
  coach           Coach?    @relation(fields: [coachId], references: [id], onDelete: SetNull)
  sponsors        Sponsor[]
  incomingTransferOffers TransferOffer[] @relation("OffersToTeam")
  outgoingTransferOffers TransferOffer[] @relation("OffersFromTeam")
  trainingSessions       TrainingSession[]
  messages        Message[]
  createdAt       DateTime  @default(now())
  matchesAsTeam1  Match[]   @relation("Team1")
  matchesAsTeam2  Match[]   @relation("Team2")
  scrims          Scrim[]

  @@index([saveId])
  @@index([saveId, isPlayerTeam])
}

model Player {
  id            String     @id @default(cuid())
  ign           String
  firstName     String
  lastName      String
  nationality   String
  age           Int
  role            Role
  leadershipRole  LeadershipRole @default(Support)
  imageUrl        String?
  currentTeam   String?
  region        Region
  tier          PlayerTier @default(VCT)
  salary        Int
  acs           Float
  kd            Float
  adr           Float
  kast          Float
  hs            Float
  mapFactors    Json       @default("{}")
  joinedWeek    Int        @default(0)
  pandascoreId  String?
  isActive      Boolean    @default(true)
  isRetired     Boolean    @default(false)
  teamId        String?
  // Cascade delete: when a save is deleted its teams cascade, and their players
  // go with them. Otherwise cloned players pollute the template pool as orphans.
  team          Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  contractEndSeason Int       @default(1)
  contractEndWeek   Int       @default(52)
  buyoutClause      Int       @default(0)
  incomingOffers    TransferOffer[]
  trainingSessions  TrainingSession[]
  injuries          Injury[]
  createdAt     DateTime   @default(now())

  @@index([teamId])
  @@index([pandascoreId])
}

model Coach {
  id           String  @id @default(cuid())
  saveId       String?
  save         Save?   @relation(fields: [saveId], references: [id], onDelete: Cascade)
  name         String
  nationality  String
  age          Int
  salary       Int
  utilityBoost Int     @default(50)
  trainingEff  Int     @default(50)
  scoutingSkill Int    @default(50)
  imageUrl     String?
  contractEndSeason Int @default(1)
  contractEndWeek   Int @default(52)
  teams        Team[]

  @@index([saveId])
}

model Sponsor {
  id              String   @id @default(cuid())
  saveId          String?
  save            Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  teamId          String
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name            String
  tier            SponsorTier
  weeklyPayment   Int
  winBonus        Int      @default(0)
  champPtsBonus   Int      @default(0)
  contractEndSeason Int
  contractEndWeek   Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([saveId])
  @@index([teamId])
}

model TransferOffer {
  id             String   @id @default(cuid())
  saveId         String?
  save           Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  playerId       String
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  fromTeamId     String
  fromTeam       Team     @relation("OffersFromTeam", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeamId       String?
  toTeam         Team?    @relation("OffersToTeam", fields: [toTeamId], references: [id], onDelete: Cascade)
  offerType      OfferType
  transferFee    Int      @default(0)
  proposedSalary Int
  contractLengthWeeks Int  @default(52)
  status         OfferStatus @default(PENDING)
  week           Int
  season         Int
  createdAt      DateTime @default(now())

  @@index([saveId])
}

model TrainingSession {
  id        String        @id @default(cuid())
  saveId    String?
  save      Save?         @relation(fields: [saveId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  focus     TrainingFocus
  agentName String?
  mapName   String?
  week      Int
  season    Int
  createdAt DateTime      @default(now())

  @@index([saveId])
}

model Message {
  id             String   @id @default(cuid())
  saveId         String?
  save           Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  teamId         String
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  category       MessageCategory
  fromName       String
  fromRole       String
  subject        String
  body           String   @db.Text
  eventType      String?
  eventData      Json?
  isRead         Boolean  @default(false)
  requiresAction Boolean  @default(false)
  actionResolved Boolean  @default(false)
  actionResult   String?
  week           Int
  season         Int
  createdAt      DateTime @default(now())

  @@index([saveId])
  @@index([teamId])
}

enum MessageCategory {
  MATCH
  PLAYER
  COACH
  SPONSOR
  BOARD
  MARKET
  NEWS
  MEDIA
}

model Injury {
  id           String   @id @default(cuid())
  saveId       String?
  save         Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  playerId     String
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  startWeek    Int
  startSeason  Int
  endWeek      Int
  endSeason    Int
  severity     String
  description  String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([saveId])
}

model MetaPatch {
  id        String   @id @default(cuid())
  saveId    String?
  save      Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  season    Int
  stage     String
  buffs     Json
  nerfs     Json
  notes     String?
  createdAt DateTime @default(now())

  @@index([saveId])
}

model Match {
  id        String      @id @default(cuid())
  saveId    String?
  save      Save?       @relation(fields: [saveId], references: [id], onDelete: Cascade)
  stageId   String
  day       Int
  week      Int
  season    Int         @default(1)
  format    MatchFormat
  team1Id   String
  team2Id   String
  team1     Team        @relation("Team1", fields: [team1Id], references: [id], onDelete: Cascade)
  team2     Team        @relation("Team2", fields: [team2Id], references: [id], onDelete: Cascade)
  winnerId  String?
  score     Json?
  maps      Json?
  isPlayed  Boolean     @default(false)
  playedAt  DateTime?

  @@index([saveId])
  @@index([saveId, stageId])
  @@index([saveId, isPlayed])
}

model Season {
  id            String   @id @default(cuid())
  saveId        String?  @unique
  save          Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  number        Int      @default(1)
  year          Int      @default(2026)
  currentStage  String   @default("KICKOFF")
  currentDay    Int      @default(1)
  currentWeek   Int      @default(1)
  masters1City  String   @default("Santiago")
  masters2City  String   @default("London")
  championsCity String   @default("Shanghai")
  isActive      Boolean  @default(true)
  startedAt     DateTime @default(now())
}

// Preset templates — GLOBAL (not scoped by save). Used to clone AI teams when a new save is created.
model VctTeamTemplate {
  id       String @id @default(cuid())
  name     String
  tag      String
  region   Region
  logoUrl  String?
  budget   Int
  prestige Int
}

enum Region {
  EMEA
  Americas
  Pacific
  China
}

enum Role {
  IGL
  Duelist
  Initiator
  Sentinel
  Controller
  Flex
}

enum LeadershipRole {
  IGL
  Entry
  Support
  Lurker
  Anchor
}

enum MatchFormat {
  BO1
  BO3
  BO5
}

enum PlayerTier {
  VCT
  VCL
}

enum Playstyle {
  Aggressive
  Tactical
  Defensive
  Balanced
  Flex
}

enum SponsorTier {
  Tier1
  Tier2
  Tier3
}

enum OfferType {
  FREE_AGENT_SIGNING
  BUYOUT
  CONTRACT_EXTENSION
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  COUNTERED
}

enum TrainingFocus {
  AGENT_MASTERY
  MAP_FACTOR
  TEAM_SYNERGY
  AIM
  UTILITY
}

model MapPool {
  id        String   @id @default(cuid())
  saveId    String?
  save      Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  season    Int
  patchId   String
  maps      Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([saveId])
}

model PlayerAgentPool {
  id              String @id @default(cuid())
  saveId          String?
  save            Save?  @relation(fields: [saveId], references: [id], onDelete: Cascade)
  playerId        String
  agentName       String
  mapName         String
  stars           Float  @default(1)
  lastPlayedMatch Int    @default(0)

  @@unique([playerId, agentName, mapName])
  @@index([saveId])
}

model Scrim {
  id           String   @id @default(cuid())
  saveId       String?
  save         Save?    @relation(fields: [saveId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  opponentId   String
  mapName      String
  season       Int
  week         Int
  fakeComp     Boolean  @default(false)
  accepted     Boolean  @default(false)
  refused      Boolean  @default(false)
  result       Json?
  reliability  Float    @default(1.0)
  createdAt    DateTime @default(now())

  @@index([saveId])
}
