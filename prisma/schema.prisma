generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  team      Team?
}

model Team {
  id             String   @id @default(cuid())
  name           String
  tag            String
  region         Region
  logoUrl        String?
  budget         Int      @default(1000000)
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  players        Player[]
  skillAim         Int       @default(0)
  skillUtility     Int       @default(0)
  skillTeamplay    Int       @default(0)
  lastTrainedWeek  Int       @default(0)
  wins            Int       @default(0)
  losses          Int       @default(0)
  champPts        Int       @default(0)
  prestige        Int       @default(50)
  playstyle       Playstyle @default(Balanced)
  coachId         String?
  coach           Coach?    @relation(fields: [coachId], references: [id])
  sponsors        Sponsor[]
  incomingTransferOffers TransferOffer[] @relation("OffersToTeam")
  outgoingTransferOffers TransferOffer[] @relation("OffersFromTeam")
  trainingSessions       TrainingSession[]
  messages        Message[]
  createdAt       DateTime  @default(now())
  matchesAsTeam1  Match[]   @relation("Team1")
  matchesAsTeam2  Match[]   @relation("Team2")
}

model Player {
  id            String     @id @default(cuid())
  ign           String
  firstName     String
  lastName      String
  nationality   String
  age           Int
  role            Role
  leadershipRole  LeadershipRole @default(Support)
  imageUrl        String?
  currentTeam   String?
  region        Region
  tier          PlayerTier @default(VCT)
  salary        Int
  acs           Float
  kd            Float
  adr           Float
  kast          Float
  hs            Float
  mapFactors    Json       @default("{}")  // { "Bind": 1.10, "Haven": 0.88, ... } per map
  joinedWeek    Int        @default(0)    // game week when player joined the team (for synergy calc)
  pandascoreId  String?    @unique
  isActive      Boolean    @default(true)
  isRetired     Boolean    @default(false)
  teamId        String?
  team          Team?      @relation(fields: [teamId], references: [id])
  // Contract fields
  contractEndSeason Int       @default(1)     // last season of contract
  contractEndWeek   Int       @default(52)    // last week of contract within that season
  buyoutClause      Int       @default(0)     // buyout price in $ (0 = no clause)
  incomingOffers    TransferOffer[]
  trainingSessions  TrainingSession[]
  injuries          Injury[]
  createdAt     DateTime   @default(now())
}

// ── Coach adjoint ──
model Coach {
  id           String  @id @default(cuid())
  name         String
  nationality  String
  age          Int
  salary       Int
  // Stats 0-100
  utilityBoost Int     @default(50) // team skill boost
  trainingEff  Int     @default(50) // mastery gain boost
  scoutingSkill Int    @default(50) // better scouting
  imageUrl     String?
  contractEndSeason Int @default(1)
  contractEndWeek   Int @default(52)
  teams        Team[]
}

// ── Sponsors ──
model Sponsor {
  id              String   @id @default(cuid())
  teamId          String
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name            String
  tier            SponsorTier
  weeklyPayment   Int
  winBonus        Int      @default(0)    // per match win
  champPtsBonus   Int      @default(0)    // per championship point earned
  contractEndSeason Int
  contractEndWeek   Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

// ── Transfer offers (contract/buyout negotiations) ──
model TransferOffer {
  id             String   @id @default(cuid())
  playerId       String
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  fromTeamId     String   // team making the offer
  fromTeam       Team     @relation("OffersFromTeam", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeamId       String?  // team receiving the offer (null if FA signing)
  toTeam         Team?    @relation("OffersToTeam", fields: [toTeamId], references: [id], onDelete: Cascade)
  offerType      OfferType
  transferFee    Int      @default(0)   // for buyouts
  proposedSalary Int                    // salary offered to player
  contractLengthWeeks Int  @default(52) // duration in weeks
  status         OfferStatus @default(PENDING)
  week           Int
  season         Int
  createdAt      DateTime @default(now())
}

// ── Training sessions ──
model TrainingSession {
  id        String        @id @default(cuid())
  teamId    String
  team      Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  focus     TrainingFocus
  agentName String?       // for AGENT_MASTERY focus
  mapName   String?       // for MAP_FACTOR or AGENT_MASTERY focus
  week      Int
  season    Int
  createdAt DateTime      @default(now())
}

// ── Messages / Inbox / Random events ──
model Message {
  id             String   @id @default(cuid())
  teamId         String
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  category       MessageCategory
  fromName       String   // "Sliggy", "Boaster", "Riot HQ", "Team Owner"
  fromRole       String   // "Coach", "Player", "Board", "Sponsor", "Press", "Riot"
  subject        String
  body           String   // multi-line markdown-ish OK
  eventType      String?  // "player_unhappy" | "injury" | "poach_offer" | "sponsor_bonus" | ...
  eventData      Json?    // { playerId, amount, agentName, ... } — context for resolution
  isRead         Boolean  @default(false)
  requiresAction Boolean  @default(false)
  actionResolved Boolean  @default(false)
  actionResult   String?  // "accepted" | "rejected" | "ignored"
  week           Int
  season         Int
  createdAt      DateTime @default(now())
}

enum MessageCategory {
  MATCH
  PLAYER
  COACH
  SPONSOR
  BOARD
  MARKET
  NEWS
  MEDIA
}

// ── Injuries ──
model Injury {
  id           String   @id @default(cuid())
  playerId     String
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  startWeek    Int
  startSeason  Int
  endWeek      Int
  endSeason    Int
  severity     String   // "minor" | "moderate" | "severe"
  description  String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ── Meta patches (agent buffs/nerfs per stage) ──
model MetaPatch {
  id        String   @id @default(cuid())
  season    Int
  stage     String   // KICKOFF, MASTERS_1, STAGE_1, etc.
  buffs     Json     @default("[]")  // string[] of buffed agent names
  nerfs     Json     @default("[]")  // string[] of nerfed agent names
  notes     String?
  createdAt DateTime @default(now())
}

model Match {
  id        String      @id @default(cuid())
  stageId   String
  day       Int
  week      Int
  season    Int         @default(1)
  format    MatchFormat
  team1Id   String
  team2Id   String
  team1     Team        @relation("Team1", fields: [team1Id], references: [id])
  team2     Team        @relation("Team2", fields: [team2Id], references: [id])
  winnerId  String?
  score     Json?
  maps      Json?
  isPlayed  Boolean     @default(false)
  playedAt  DateTime?
}

model Season {
  id            String   @id @default(cuid())
  number        Int      @default(1)
  year          Int      @default(2026)
  currentStage  String   @default("KICKOFF")
  currentDay    Int      @default(1)
  currentWeek   Int      @default(1)
  masters1City  String   @default("Santiago")
  masters2City  String   @default("London")
  championsCity String   @default("Shanghai")
  isActive      Boolean  @default(true)
  startedAt     DateTime @default(now())
}

model VctTeamTemplate {
  id       String @id @default(cuid())
  name     String
  tag      String
  region   Region
  logoUrl  String?
  budget   Int
  prestige Int
}

enum Region {
  EMEA
  Americas
  Pacific
  China
}

enum Role {
  IGL
  Duelist
  Initiator
  Sentinel
  Controller
  Flex
}

enum LeadershipRole {
  IGL
  Entry
  Support
  Lurker
  Anchor
}

enum MatchFormat {
  BO1
  BO3
  BO5
}

enum PlayerTier {
  VCT
  VCL
}

enum Playstyle {
  Aggressive
  Tactical
  Defensive
  Balanced
  Flex
}

enum SponsorTier {
  Tier1
  Tier2
  Tier3
}

enum OfferType {
  FREE_AGENT_SIGNING
  BUYOUT
  CONTRACT_EXTENSION
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  COUNTERED
}

enum TrainingFocus {
  AGENT_MASTERY
  MAP_FACTOR
  TEAM_SYNERGY
  AIM
  UTILITY
}

model MapPool {
  id        String   @id @default(cuid())
  season    Int
  patchId   String
  maps      Json     // string[] of map names in the active pool
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PlayerAgentPool {
  id              String @id @default(cuid())
  playerId        String
  agentName       String
  mapName         String
  stars           Float  @default(1) // 0.0-5.0 mastery (finer progression)
  lastPlayedMatch Int    @default(0) // match counter for passive decay

  @@unique([playerId, agentName, mapName])
}

model Scrim {
  id           String   @id @default(cuid())
  teamId       String
  opponentId   String
  mapName      String
  season       Int
  week         Int
  fakeComp     Boolean  @default(false)
  accepted     Boolean  @default(false)
  refused      Boolean  @default(false)
  result       Json?    // { score1, score2, myComp: string[], oppComp: string[] }
  reliability  Float    @default(1.0) // decays 0.25 per patch
  createdAt    DateTime @default(now())
}
